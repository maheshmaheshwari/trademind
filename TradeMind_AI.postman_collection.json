{
	"info": {
		"_postman_id": "trademind-ai-collection",
		"name": "TradeMind AI - Complete API Collection",
		"description": "All API endpoints for the TradeMind AI trading platform.\n\nBase URL: http://localhost:8000\n\nAuthentication: Bearer token (obtained from /api/trading/login)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "2",
			"type": "string"
		},
		{
			"key": "symbol",
			"value": "TCS.NS",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "🏠 Health & Root",
			"item": [
				{
					"name": "Root",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": ["{{base_url}}"],
							"path": [""]
						},
						"description": "Root endpoint — returns app info and status."
					}
				},
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/health",
							"host": ["{{base_url}}"],
							"path": ["api", "health"]
						},
						"description": "Health check — returns DB status, stock count, and latest data date."
					}
				}
			]
		},
		{
			"name": "🔐 Auth & Users",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    pm.collectionVariables.set('user_id', jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"newuser\",\n    \"password\": \"password123\",\n    \"display_name\": \"New User\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/trading/register",
							"host": ["{{base_url}}"],
							"path": ["api", "trading", "register"]
						},
						"description": "Register a new user. Returns JWT token and user object."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    pm.collectionVariables.set('user_id', jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"maheshmaheshwari\",\n    \"password\": \"mahesh\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/trading/login",
							"host": ["{{base_url}}"],
							"path": ["api", "trading", "login"]
						},
						"description": "Login with username/password. Returns JWT token."
					}
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/trading/me",
							"host": ["{{base_url}}"],
							"path": ["api", "trading", "me"]
						},
						"description": "Get the currently authenticated user profile."
					}
				},
				{
					"name": "Get User by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/trading/user/{{user_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "trading", "user", "{{user_id}}"]
						},
						"description": "Get user details by user ID."
					}
				},
				{
					"name": "Get User by Username",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/trading/user/by-username/maheshmaheshwari",
							"host": ["{{base_url}}"],
							"path": ["api", "trading", "user", "by-username", "maheshmaheshwari"]
						},
						"description": "Get user details by username."
					}
				},
				{
					"name": "Create User (legacy)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"display_name\": \"Test User\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/trading/user",
							"host": ["{{base_url}}"],
							"path": ["api", "trading", "user"]
						},
						"description": "Create a new trading user (legacy endpoint, prefer /register)."
					}
				}
			]
		},
