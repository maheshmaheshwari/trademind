# ============================================================
# TradeMind AI — Environment Variables
# Copy this file to .env and fill in each value.
# See ENV_VARIABLES.md for detailed instructions on where
# to find each value.
# ============================================================

# ------------------------------------------------------------
# TimescaleDB (PostgreSQL)
# Get these from: cloud.timescale.com → your service → Connection info
# ------------------------------------------------------------
PGHOST=your_timescale_host.tsdb.cloud.timescale.com
PGPORT=5432
PGDATABASE=tsdb
PGUSER=tsdbadmin
PGPASSWORD=your_timescale_password

# ------------------------------------------------------------
# Angel One SmartAPI
# API key + secret: smartapi.angelone.in → My Apps
# Client ID + password: your Angel One trading account credentials
# TOTP secret: Angel One → Profile → Security Settings → TOTP setup
# ------------------------------------------------------------
ANGEL_API_KEY=your_angel_api_key
ANGEL_SECRET_KEY=your_angel_secret_key
ANGEL_CLIENT_ID=your_client_id
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_totp_base32_secret

# ------------------------------------------------------------
# JWT Auth
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
JWT_SECRET=replace_with_output_of_openssl_rand_hex_32

# ------------------------------------------------------------
# News APIs (optional — news collection is skipped if missing)
# NEWSAPI_KEY: newsapi.org → Dashboard (free tier: 100 req/day)
# ALPHAVANTAGE_API_KEY: alphavantage.co/support/#api-key (free, no account needed)
# ------------------------------------------------------------
NEWSAPI_KEY=your_newsapi_key
ALPHAVANTAGE_API_KEY=your_alphavantage_key

# ------------------------------------------------------------
# App Config (optional — defaults shown)
# ------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO
