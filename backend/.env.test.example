# ============================================================
# TradeMind AI — TEST database overrides template
#
# Copy to backend/.env.test and fill in your dedicated test
# Timescale Cloud instance's credentials. Loaded only when
# APP_ENV=test is set (see database/db.py and CLAUDE.md
# "Testing & Test Database"). Real backend/.env.test is
# gitignored — never commit actual credentials.
# ============================================================
PGHOST=your-test-instance.tsdb.cloud.timescale.com
PGPORT=00000
PGDATABASE=tsdb
PGUSER=tsdbadmin
PGPASSWORD=changeme
PGSSLMODE=require
